# api-key
OPENAI_API_KEY=your_openai_api-key
ANTHROPIC_API_KEY=your_anthropic_api-key
GOOGLE_API_KEY=your_google_api-key

# default-model
CHATGPT_MODEL_NAME=gpt-5-mini

# vertorDB & DB
OPENSEARCH_API_URL=http://host.docker.internal:8010
DATABASE_API_URL=http://host.docker.internal:8020

# PostgreSQL (SQLAlchemy direct connection)
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_DB=ai_innovation_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

# LangSmith Tracing (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=crm-agent-dev

# PostgreSQL (LangGraph Checkpointer)
POSTGRES_URL=postgresql://user:password@host.docker.internal:5432/ai_innovation_db

# Logging
LOG_LEVEL=INFO
ENVIRONMENT=development

# CORS (JSON 배열 형식, 프로덕션에서는 실제 도메인으로 교체)
ALLOWED_ORIGINS=["http://localhost:3000"]

# LLM 타임아웃 (초) — 구조화 문서 생성은 이미지 텍스트가 길어 별도 타임아웃 적용
LLM_DOCUMENT_TIMEOUT=150

# 상품 추천 — RRF 스코어 최소 임계값 (5쿼리 기준 최대 ~0.082, 기본 0.01은 사실상 순위 기반 top-3 선택)
MIN_RRF_SCORE_THRESHOLD=0.01

# 상품 추천 — RRF 상수 k (표준값 60, 값이 클수록 rank 차이 완화)
RRF_K=60

# 상품 추천 — DB 필터 최소 상품 수 (이 값 미만이면 Fallback으로 필터 단계적 완화)
MIN_FILTERED_PRODUCTS=3

# LangGraph
LANGGRAPH_RECURSION_LIMIT=100

# A2A Agent URLs (로컬: localhost, Docker: 서비스명 사용)
RECOMMEND_AGENT_URL=http://localhost:8001
GENERATE_MESSAGE_AGENT_URL=http://localhost:8002
DATA_REGISTRATION_AGENT_URL=http://localhost:8003

# Auth
AUTH_MODE=jwt
SERVICE_API_KEY=change-this-to-a-strong-random-secret
JWT_SECRET=<openssl rand -hex 32 결과 — 최소 32자>

# Internal service-to-service token (서비스 간 통신 인증 — openssl rand -hex 32)
INTERNAL_TOKEN=change-this-to-a-strong-random-secret