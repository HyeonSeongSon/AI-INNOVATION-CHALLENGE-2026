# OpenSearch 연결 설정
OPENSEARCH_ADMIN_USER=admin
OPENSEARCH_ADMIN_PASSWORD=MyStrongPassword123!
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
# 보안 활성(HTTPS) 클러스터면 true. 로컬 docker-compose는 compose가 true로 덮어쓰며,
# AWS 단일노드(plugins.security.disabled, 평문 HTTP)는 false로 둔다.
OPENSEARCH_USE_SSL=false

# FastAPI 설정
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8010

# 환경 (local, production)
ENVIRONMENT=local

# Internal service-to-service token (서비스 간 통신 인증 — openssl rand -hex 32)
INTERNAL_TOKEN=change-this-to-a-strong-random-secret
